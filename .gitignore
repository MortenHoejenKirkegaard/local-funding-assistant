.DS_Store
.env
.env.*
!.env.example

# Local runtime state
logs/
tmp/
*.log
!funding-assistant/system/logs/
!funding-assistant/system/logs/.gitkeep
!funding-assistant-test/system/logs/
!funding-assistant-test/system/logs/.gitkeep

# Databases and local service volumes
data/
postgres-data/
qdrant-storage/

# Generated outputs can contain confidential material.
funding-assistant/outputs/**
!funding-assistant/outputs/**/.gitkeep

# Source snapshots may contain downloaded funder pages or PDFs.
funding-assistant/funding/source_snapshots/**
!funding-assistant/funding/source_snapshots/.gitkeep

# Portfolio and application documents are confidential by default.
funding-assistant/cases/**/*.doc
funding-assistant/cases/**/*.docx
funding-assistant/cases/**/*.xls
funding-assistant/cases/**/*.xlsx
funding-assistant/cases/**/*.ppt
funding-assistant/cases/**/*.pptx
funding-assistant/cases/**/*.pdf
funding-assistant/cases/**/*.png
funding-assistant/cases/**/*.jpg
funding-assistant/cases/**/*.jpeg
funding-assistant/cases/**/*.tif
funding-assistant/cases/**/*.tiff

funding-assistant/applications/historical/**/*.doc
funding-assistant/applications/historical/**/*.docx
funding-assistant/applications/historical/**/*.xls
funding-assistant/applications/historical/**/*.xlsx
funding-assistant/applications/historical/**/*.ppt
funding-assistant/applications/historical/**/*.pptx
funding-assistant/applications/historical/**/*.pdf

# Test environment input/output may still contain real documents during trials.
funding-assistant-test/**/*.doc
funding-assistant-test/**/*.docx
funding-assistant-test/**/*.xls
funding-assistant-test/**/*.xlsx
funding-assistant-test/**/*.ppt
funding-assistant-test/**/*.pptx
funding-assistant-test/**/*.pdf
funding-assistant-test/**/*.png
funding-assistant-test/**/*.jpg
funding-assistant-test/**/*.jpeg
funding-assistant-test/**/*.tif
funding-assistant-test/**/*.tiff
funding-assistant-test/**/*.txt
funding-assistant-test/**/*.md
funding-assistant-test/**/*.csv
funding-assistant-test/applications/**/*.jsonl
funding-assistant-test/applications/**/*.json
funding-assistant-test/system/logs/*.jsonl
funding-assistant-test/system/index/*.jsonl
funding-assistant-test/system/config/runtime.json

# Local Python/Node/Rust build artifacts for future app code.
.venv/
venv/
.pycache/
__pycache__/
node_modules/
dist/
build/
target/
